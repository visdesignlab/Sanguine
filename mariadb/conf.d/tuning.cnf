[mariadb]
# Basic Settings
# Keep connection count low because this host is small and our workload is batch-oriented.
max_connections         = 10
sql_mode                = STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION

# InnoDB Settings
# Main cache for table and index pages. This stays warm across refresh/parquet runs,
# so it is the most valuable place to spend RAM for our workload.
innodb_buffer_pool_size = 3G

# Large enough to support TRUNCATE + INSERT ... SELECT refreshes without pushing
# checkpoints too aggressively.
innodb_log_file_size    = 512M

# Supports larger batch writes without the oversized 256M memory cost.
innodb_log_buffer_size  = 64M
innodb_flush_method     = O_DIRECT
innodb_file_per_table   = 1

# Conservative IO settings for a small host/VM.
innodb_io_capacity      = 1000
innodb_read_io_threads  = 2
innodb_write_io_threads = 2

# Query & Join Optimization
# Low concurrency means these can be moderately sized, but not huge.
join_buffer_size        = 16M
sort_buffer_size        = 4M
read_buffer_size        = 2M
read_rnd_buffer_size    = 4M

# Query Cache
# Disable query cache. Our workload refreshes tables in bulk, so query cache
# invalidation/locking is more likely to hurt than help.
query_cache_type        = 0
query_cache_size        = 0
query_cache_limit       = 0

# Temporary Tables
# Large enough for some grouping/sort workloads without getting too aggressive
# on a shared 8 GB host.
tmp_table_size          = 128M
max_heap_table_size     = 128M

# Connection & Threading
thread_cache_size       = 16
table_open_cache        = 2048
open_files_limit        = 65535

# Logging
slow_query_log          = 1
slow_query_log_file     = /var/log/mysql/slow.log
long_query_time         = 2

# Character Set
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci
